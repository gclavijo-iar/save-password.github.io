<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Configurar contraseña</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>

<h2>Establecer contraseña</h2>

<input type="password" id="password" placeholder="Nueva contraseña">
<input type="password" id="confirmPassword" placeholder="Confirmar contraseña">
<button id="saveBtn">Guardar</button>

<p id="message"></p>

<script>
  const supabaseUrl = "TU_SUPABASE_URL";
  const supabaseKey = "TU_SUPABASE_ANON_KEY";

  const supabase = window.supabase.createClient(supabaseUrl, supabaseKey);
  const message = document.getElementById("message");

  // Detectar sesión creada por invite o recovery
  supabase.auth.onAuthStateChange((event, session) => {
    if (event === "PASSWORD_RECOVERY") {
      console.log("Modo recuperación");
    }
    if (event === "SIGNED_IN") {
      console.log("Usuario autenticado por enlace mágico/invitación");
    }
  });

  document.getElementById("saveBtn").addEventListener("click", async () => {

    const password = document.getElementById("password").value;
    const confirmPassword = document.getElementById("confirmPassword").value;

    const regex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;

    if (!regex.test(password)) {
      message.textContent =
        "Mínimo 8 caracteres, mayúscula, minúscula, número y símbolo.";
      return;
    }

    if (password !== confirmPassword) {
      message.textContent = "Las contraseñas no coinciden.";
      return;
    }

    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      message.textContent = "Enlace inválido o expirado.";
      return;
    }

    const { error } = await supabase.auth.updateUser({
      password: password
    });

    if (error) {
      message.textContent = "Error: " + error.message;
    } else {
      message.textContent = "Contraseña configurada correctamente.";

      // Opcional: cerrar sesión después
      // await supabase.auth.signOut();
    }
  });
</script>

</body>
</html>
