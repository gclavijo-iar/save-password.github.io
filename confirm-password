<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Configurar contraseña</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
<h2>Establecer contraseña</h2>
<input type="password" id="password" placeholder="Nueva contraseña">
<input type="password" id="confirmPassword" placeholder="Confirmar contraseña">
<button id="saveBtn">Guardar</button>
<p id="message"></p>

<script>
  const supabaseUrl = "https://wptspqcmjstvuwugcepu.supabase.co";
  const supabaseKey = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndwdHNwcWNtanN0dnV3dWdjZXB1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA2MjIxMjQsImV4cCI6MjA4NjE5ODEyNH0.teEFc_0NR8MuYygh8KPSXq3yKdPUABuoJvP5QHhZjq4";
  const supabase = window.supabase.createClient(supabaseUrl, supabaseKey);

  const message = document.getElementById("message");

  // 1️⃣ Leer el hash de la URL
  const hash = window.location.hash.substring(1); // quita el '#'
  const params = new URLSearchParams(hash);
  const access_token = params.get('access_token');

  if (!access_token) {
    message.textContent = "Enlace inválido o expirado.";
    document.getElementById("saveBtn").disabled = true;
  } else {
    // 2️⃣ Iniciar sesión temporal con Supabase
    supabase.auth.setSession({
      access_token: access_token,
      refresh_token: params.get('refresh_token')
    });
  }

  // 3️⃣ Cambiar contraseña
  document.getElementById("saveBtn").addEventListener("click", async () => {
    const password = document.getElementById("password").value;
    const confirmPassword = document.getElementById("confirmPassword").value;

    // Validación
    const regex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
    if (!regex.test(password)) {
      message.textContent = "Debe tener mínimo 8 caracteres, mayúscula, minúscula, número y símbolo.";
      return;
    }

    if (password !== confirmPassword) {
      message.textContent = "Las contraseñas no coinciden.";
      return;
    }

    // 4️⃣ Actualizar contraseña
    const { data: user, error } = await supabase.auth.updateUser({ password });

    if (error) {
      message.textContent = "Error: " + error.message;
    } else {
      message.textContent = "Contraseña configurada correctamente.";
      // Opcional: cerrar sesión
      // await supabase.auth.signOut();
    }
  });
</script>
</body>
</html>
